# Desativa o redirecionamento normal do Apache (ex: privacy iria abrir privacy.html, nós vamos fazer com que privacy abra index.php e esta vai mostrar o conteúdo de privacy.html)
Options -MultiViews
# Ativa o redirecionamento que estamos a usar neste ficheiro
RewriteEngine On

# Não redireciona nada dentro de /backoffice/, pois essa pasta vai ter outro redirecionamento dentro dela
RewriteRule ^backoffice/ - [L]

# Se for um ficheiro real...
RewriteCond %{REQUEST_FILENAME} -f
# ... mas apenas nesta pasta, redireciona para index.php
RewriteRule ^[^/]+$ index.php [L,QSA]

# Se não for um ficheiro real...
RewriteCond %{REQUEST_FILENAME} !-f
# ... redireciona para index.php
RewriteRule ^ index.php [L,QSA]